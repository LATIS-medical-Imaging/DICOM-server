# pgAdmin (web database UI — http://localhost:5050)
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Application
APP_NAME=
APP_ENV=            # development | staging | production
APP_DEBUG=
APP_HOST=
APP_PORT=
APP_LOG_LEVEL=           # DEBUG | INFO | WARNING | ERROR

CORS_ORIGINS=

# Security / JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=
JWT_REFRESH_TOKEN_EXPIRE_DAYS=

# Argon2 password hashing parameters
ARGON2_TIME_COST=
ARGON2_MEMORY_COST=
ARGON2_PARALLELISM=

# PostgreSQL (direct connection parameters)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=         # use "postgres" to bypass pooler
POSTGRES_PORT=              # 6432 = pgbouncer, 5432 = postgres direct

# SQLAlchemy pool tuning (per API worker)
DB_POOL_SIZE=
DB_MAX_OVERFLOW=
DB_POOL_TIMEOUT=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_DB=
REDIS_PASSWORD=

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=
MINIO_EXTERNAL_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=
MINIO_BUCKET_DICOM=
MINIO_BUCKET_THUMBNAILS=
MINIO_PRESIGNED_URL_EXPIRE_SECONDS=
# Override per environment — staging/prod should set the real domain.
CORS_MINIO_ORIGIN=

# Celery
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_DEFAULT_QUEUE=

# Uploads
MAX_UPLOAD_SIZE_MB=
