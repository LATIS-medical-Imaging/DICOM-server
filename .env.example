# Application
APP_NAME=dicom-server
APP_ENV=development            # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Security / JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Argon2 password hashing parameters
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# PostgreSQL (direct connection parameters)
POSTGRES_USER=dicom
POSTGRES_PASSWORD=dicom
POSTGRES_DB=dicom
POSTGRES_HOST=pgbouncer         # use "postgres" to bypass pooler
POSTGRES_PORT=6432              # 6432 = pgbouncer, 5432 = postgres direct

# SQLAlchemy pool tuning (per API worker)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_DICOM=dicom-files
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_PRESIGNED_URL_EXPIRE_SECONDS=3600

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_DEFAULT_QUEUE=default

# Uploads
MAX_UPLOAD_SIZE_MB=500
